{
    "name": "lumensistemas/br-validation-laravel",
    "description": "A Laravel package that provides validation rules for Brazilian documents.",
    "keywords": [
        "lumensistemas",
        "br-validation-laravel",
        "laravel",
        "validation",
        "cpf",
        "cnpj"
    ],
    "homepage": "https://github.com/lumensistemas/br-validation-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Lucas Vasconcelos",
            "email": "lucasvscn@pm.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^13.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "LumenSistemas\\BrValidation\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LumenSistemas\\BrValidation\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyze": "phpstan analyse --memory-limit=512M",
        "lint": ["rector process --memory-limit=512M", "pint"],
        "test": "pest --bail",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:arch": "pest --testsuite=Arch",
        "test:unit": "pest --testsuite=Unit",
        "test:feature": "pest --testsuite=Feature",
        "test:coverage": "pest --coverage --min=90",
        "test:lint": ["rector process --dry-run --clear-cache --memory-limit=512M", "pint --test"],
        "test:all": ["@test:lint", "@analyze", "@test:type-coverage", "@test:coverage"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LumenSistemas\\BrValidation\\BrValidationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
